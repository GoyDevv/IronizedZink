<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Write the runtime config to shared storage so the launcher's game process
         (a different app) can read it via the DLOPEN'd shim. Mirrors how MobileGlues
         stores its config under a public folder. -->
    <uses-permission android:name="android.permission.MANAGE_EXTERNAL_STORAGE" />
    <uses-permission
        android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="29" />
    <uses-permission
        android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.IronizedZink"
        tools:targetApi="31">

        <!--
          ============================================================
          Ironized Zink — renderer plugin descriptor
          Read by the launcher via PackageManager.queryIntentActivities
          + ApplicationInfo.metaData. Compatible with:
            * Fold Craft Launcher family   (fclPlugin)
            * ZalithLauncher 2 family       (zalithRendererPlugin)
          The launcher loads glName/eglName from this app's
          nativeLibraryDir and injects pojavEnv/boatEnv at launch.
          ============================================================
        -->
        <meta-data android:name="fclPlugin" android:value="true" />
        <meta-data android:name="zalithRendererPlugin" android:value="true" />

        <!-- "displayName:glName:eglName" (colon-separated). glName is our GL wrapper,
             which forwards to libglxshim and renames the F3 renderer string. -->
        <meta-data
            android:name="renderer"
            android:value="Ironized Zink:libironized_gl.so:libEGL_mesa.so" />

        <!-- Human-readable description shown in the renderer picker -->
        <meta-data
            android:name="des"
            android:value="Ironized Zink — desktop OpenGL 4.6 over Vulkan (by GoyDevv)" />

        <!-- Environment for the Pojav launch backend (ZalithLauncher 2 + FCL).
             DLOPEN loads our runtime shim, which applies the user's saved preset. -->
        <meta-data
            android:name="pojavEnv"
            android:value="POJAV_RENDERER=opengles3_desktopgl_zink_kopper:LIBGL_ES=3:MESA_GL_VERSION_OVERRIDE=4.6:MESA_GLSL_VERSION_OVERRIDE=460:force_glsl_extensions_warn=true:allow_higher_compat_version=true:allow_glsl_extension_directive_midshader=true:MESA_LOADER_DRIVER_OVERRIDE=zink:DLOPEN=libironized_zink.so" />

        <!-- Environment for the Boat (BoardWalk) launch backend (required by FCL) -->
        <meta-data
            android:name="boatEnv"
            android:value="POJAV_RENDERER=opengles3_desktopgl_zink_kopper:LIBGL_ES=3:MESA_GL_VERSION_OVERRIDE=4.6:MESA_GLSL_VERSION_OVERRIDE=460:force_glsl_extensions_warn=true:allow_higher_compat_version=true:allow_glsl_extension_directive_midshader=true:MESA_LOADER_DRIVER_OVERRIDE=zink:DLOPEN=libironized_zink.so" />

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.IronizedZink">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>
